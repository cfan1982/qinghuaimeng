    <content type="html"><![CDATA[<pre><code class="lua">a = 5               -- 全局变量local b = 5         -- 局部变量function joke()    c = 5           -- 全局变量    local d = 6     -- 局部变量endjoke()print(c,d)          --&gt; 5 nildo    local a = 6     -- 局部变量    b = 6           -- 对局部变量重新赋值    print(a,b);     --&gt; 6 6endprint(a,b)      --&gt; 5 6</code></pre>]]></content>
    
    
      
      
